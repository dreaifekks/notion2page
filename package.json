{
  "name": "notion2page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generate static two-level project portfolio pages from Notion data sources.",
  "bin": {
    "notion2page": "./src/cli.js"
  },
  "scripts": {
