NOTION_TOKEN=secret_xxx
# You can use the database ID from the Notion URL or the resolved data source ID.
NOTION_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: mirror Notion-hosted images to Cloudflare R2 during build.
# The bucket must be reachable through a public R2 URL or custom domain.
# ASSET_MIRROR_PROVIDER=r2
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_BUCKET=notion2page-assets
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_PUBLIC_URL=https://assets.example.com
# R2_PREFIX=notion2page
# R2_MIRROR_EXTERNAL=false
# R2_URL_STYLE=virtualHosted
